version: 0.1

component: build

timeoutInSeconds: 600

shell: bash

env:
  variables:
    NODE_ENV: production

phases:
  install:
    commands:
      - echo "Installing dependencies..."
      - npm install

  build:
    commands:
      - echo "Building React app..."
      - npm run build

  post_build:
    commands:
      - echo "Build completed successfully"

artifacts:
  files:
    - build/**/*
